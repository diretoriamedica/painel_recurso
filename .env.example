# ─── Banco: Google Cloud SQL (instância rhc-sistemas, database painelrecurso) ───
#
# RUNTIME (Vercel): conexão via Cloud SQL Connector + service account (mTLS, sem IP público).
#   Estas variáveis vão nas Env Vars do projeto na Vercel (produção), NÃO em DATABASE_URL:
#   CLOUD_SQL_INSTANCE="corded-elevator-501121-q9:southamerica-east1:rhc-sistemas"
#   GCP_SA_KEY='{...JSON da service account vercel-cloudsql (role Cloud SQL Client)...}'
#   PGUSER="painelrecurso"
#   PGPASSWORD="<senha>"
#   PGDATABASE="painelrecurso"
#
# LOCAL/CLI (prisma db push, seed, scripts): use o Cloud SQL Auth Proxy + as URLs abaixo.
#   cloud-sql-proxy --gcloud-auth --port 5434 corded-elevator-501121-q9:southamerica-east1:rhc-sistemas
DATABASE_URL="postgresql://painelrecurso:SENHA@127.0.0.1:5434/painelrecurso?sslmode=disable"
DIRECT_URL="postgresql://painelrecurso:SENHA@127.0.0.1:5434/painelrecurso?sslmode=disable"

# ─── NextAuth ───
NEXTAUTH_SECRET="troque-por-um-segredo-forte"
NEXTAUTH_URL="http://localhost:3000/painelrecurso"

# ─── Resend (alertas por e-mail) ───
RESEND_API_KEY="re_..."
RESEND_FROM="Painel Recurso <alertas@seu-dominio-verificado.com>"
